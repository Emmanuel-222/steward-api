# Database (PostgreSQL - required by Prisma schema)
# Use direct connection, not pooler, to avoid Prisma prepared statement issues
DATABASE_URL=postgresql://postgres:password@localhost:5432/stewarddb

# JWT Authentication (used in middleware/authenticate.js and routes/auth.js)
JWT_SECRET=change-this-to-a-random-secret

# CORS origins (used in app.js). Comma-separated, no quotes
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:4173
